{
  "nodeModulesDir": "auto",
  "desktop": {
    "app": {
      "name": "Mermaid Reviewer",
      "identifier": "dev.sukemaru.mermaid-reviewer",
      "icons": {
        "macos": "./assets/icon.icns"
      }
    },
    "backend": "cef"
  },
  "tasks": {
    "dev": "vite --host 0.0.0.0 --port 8000",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port 8000",
    "icon:macos": "deno run --allow-read=./assets/icon.png --allow-write=./assets/icon.icns scripts/generate_macos_icon.ts",
    "desktop": "deno task icon:macos && deno task build && deno desktop --allow-read --allow-write --allow-run=osascript --allow-env=HOME --include=./dist --output ./build/MermaidReviewerCEF.app desktop.ts",
    "desktop:webview": "deno task build && deno desktop --backend=webview --allow-read --allow-write --allow-run=osascript --allow-env=HOME --include=./dist --output ./build/MermaidReviewer.app desktop.ts",
    "desktop:hmr": "deno desktop --hmr .",
    "install:cli": "deno install --global --name reviwers --allow-run=deno,open --allow-read --allow-write --allow-env=HOME cli.ts"
  },
  "imports": {
    "@deno/vite-plugin": "npm:@deno/vite-plugin@2.0.2",
    "@std/assert": "jsr:@std/assert@1.0.13",
    "lucide-preact": "npm:lucide-preact@1.24.0",
    "mermaid": "npm:mermaid@11.16.0",
    "preact": "npm:preact@10.29.2",
    "preact/hooks": "npm:preact@10.29.2/hooks",
    "vite": "npm:vite@8.1.4"
  }
}
